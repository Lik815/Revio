{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "simulator": {
      "ios": {
        "simulator": true
      }
    },
    "main": {
      "distribution": "internal",
      "channel": "main",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "main"
    }
  },
  "submit": {
    "production": {}
  }
}
