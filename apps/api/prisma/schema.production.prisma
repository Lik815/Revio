generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  SUSPENDED
}

enum EmploymentStatus {
  SELF_EMPLOYED
  PREPARING
}

enum LinkStatus {
  PROPOSED
  CONFIRMED
  DISPUTED
  REJECTED
}

enum SuggestionType {
  THERAPIST_NAME
  PRACTICE_NAME
  SPECIALTY
  CITY
}

enum Role {
  therapist
  manager
  admin
  patient
}

enum BookingMode {
  DIRECTORY_ONLY
  FIRST_APPOINTMENT_REQUEST
}

enum BookingRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  EXPIRED
}

enum AppFeedbackStatus {
  NEW
  RESOLVED
}

enum CancelledBy {
  PATIENT
  THERAPIST
}

enum TherapistReviewStatus {
  PUBLISHED
  HIDDEN
  REPORTED
}

// Phase 1 — Datenmodell MVP

enum AbsenceGrund {
  URLAUB
  FORTBILDUNG
  KRANKHEIT
  SONSTIGES
}

enum ScheduledSlotStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum InquirySlotStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum QualifikationStatus {
  UNGEPRÜFT
  EINGEREICHT
  VERIFIZIERT
  ABGELAUFEN
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String?
  sessionToken              String?   @unique
  sessionTokenExpiresAt     DateTime?
  role                   Role
  firstName                   String?
  lastName                    String?
  emailVerificationToken      String?
  emailVerifiedAt             DateTime?
  requiresEmailVerification   Boolean   @default(false)
  passwordResetToken          String?
  passwordResetExpiresAt      DateTime?
  emailOtpCode                String?
  emailOtpExpiresAt           DateTime?
  phone                       String?
  kassenart                   String?
  expoPushToken               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  therapistProfile       Therapist?              @relation("TherapistUser")
  managerProfile         PracticeManager?
  favoriteTherapists     UserFavoriteTherapist[]
  bookingRequests        BookingRequest[]
  patientRequests        PatientRequest[]        @relation("PatientRequests")
  appFeedbacks           AppFeedback[]
  therapistReviews       TherapistReview[]
  notifications          Notification[]
}

model Therapist {
  id                    String       @id @default(cuid())
  email                 String       @unique
  userId                String?      @unique
  user                  User?        @relation("TherapistUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName              String
  professionalTitle     String
  city                  String
  postalCode            String?
  street                String?
  houseNumber           String?
  locationPrecision     String       @default("approximate")
  bio                   String?
  homeVisit             Boolean      @default(false)
  isFreelancer          Boolean      @default(true)
  specializations       String
  languages             String
  certifications        String       @default("")
  heilmittel            String       @default("")
  kassenart             String       @default("")
  gender                String?
  availability          String       @default("")
  serviceRadiusKm       Float?
  latitude              Float?
  longitude             Float?
  homeLat               Float        @default(0)
  homeLng               Float        @default(0)
  isVisible             Boolean      @default(true)
  reviewStatus          ReviewStatus @default(PENDING_REVIEW)
  employmentStatus      EmploymentStatus @default(SELF_EMPLOYED)
  passwordHash          String?
  sessionToken          String?      @unique
  sessionTokenExpiresAt DateTime?
  photo                 String?
  expoPushToken         String?
  autoAcceptEnabled     Boolean      @default(false)
  autoAcceptSingle      Boolean      @default(false)
  autoAcceptSeries      Boolean      @default(false)
  taxRegistrationStatus String?
  healthAuthorityStatus String?
  complianceUpdatedAt   DateTime?
  invitedByPracticeId   String?
  onboardingStatus      String       @default("none")
  visibilityPreference  String       @default("hidden")
  isPublished           Boolean      @default(false)
  bookingMode           BookingMode  @default(DIRECTORY_ONLY)
  nextFreeSlotAt        DateTime?
  phone                 String?
  qualifikationenStatus QualifikationStatus @default(UNGEPRÜFT)
  qualifikationenVerifiziertAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  links                 TherapistPracticeLink[]
  invitations           Invitation[]
  managerAccount        PracticeManager? @relation("ManagerTherapist")
  documents             TherapistDocument[]
  bookingRequests       BookingRequest[]
  favoritedBy           UserFavoriteTherapist[]
  workingHoursRules     TherapistWorkingHoursRule[]
  services              TherapistService[]
  blockedTimes          TherapistBlockedTime[]
  absences              TherapistAbsence[]
  scheduledSlots        ScheduledSlot[]
  inquiries             Inquiry[]               @relation("TherapistInquiries")
  reviews               TherapistReview[]
  courses               Course[]                @relation("TherapistCourses")
  notifications         Notification[]
}

// Server-seitiges Notification-Log — Ersatz für den zuvor rein virtuellen
// (aus BookingRequest/Inquiry/ReviewStatus berechneten) Mitteilungen-Feed.
// Genau ein Empfänger pro Zeile (userId ODER therapistId). readAt ersetzt den
// bisherigen geräte-lokalen AsyncStorage-Read-State (revio_read_notif_ids),
// damit der Gelesen-Status geräteübergreifend synchron ist.
model Notification {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapistId  String?
  therapist    Therapist? @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  type         String
  message      String
  bookingId    String?
  inquiryId    String?
  linkId       String?
  practiceId   String?
  reviewStatus String?
  actionLabel  String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([therapistId, createdAt])
}

model Practice {
  id                String       @id @default(cuid())
  name              String
  city              String
  address           String?
  phone             String?
  hours             String?
  lat               Float        @default(0)
  lng               Float        @default(0)
  reviewStatus      ReviewStatus @default(PENDING_REVIEW)
  description       String?
  homeVisit         Boolean      @default(false)
  inviteToken       String?      @unique
  logo              String?
  photos            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  links             TherapistPracticeLink[]
  invitations       Invitation[]
  assignments       ManagerPracticeAssignment[]
  courses           Course[]                    @relation("PracticeCourses")
}

model PracticeManager {
  id           String    @id @default(cuid())
  email        String    @unique
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  passwordHash String
  sessionToken String?   @unique
  practiceId   String?
  therapistId  String?   @unique
  therapist    Therapist? @relation("ManagerTherapist", fields: [therapistId], references: [id])
  assignments  ManagerPracticeAssignment[]
  createdAt    DateTime  @default(now())
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  therapistId String
  practiceId  String
  email       String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model SearchSuggestion {
  id         String         @id @default(cuid())
  text       String
  normalized String
  type       SuggestionType
  entityId   String?
  weight     Int            @default(1)

  @@index([normalized])
}

model TherapistPracticeLink {
  id           String     @id @default(cuid())
  therapistId  String
  practiceId   String
  status       LinkStatus @default(PROPOSED)
  initiatedBy  String     @default("THERAPIST") // "ADMIN" | "THERAPIST"
  createdAt    DateTime   @default(now())
  therapist    Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice     Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([therapistId, practiceId])
}

model TherapistDocument {
  id           String    @id @default(cuid())
  therapistId  String
  filename     String    // stored filename (UUID-based, no path)
  originalName String    // original filename from upload
  mimetype     String
  uploadedAt   DateTime  @default(now())
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  authorName  String   @default("Revio Team")
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppFeedback {
  id              String            @id @default(cuid())
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String
  message         String
  status          AppFeedbackStatus @default(NEW)
  isAuthenticated Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model TherapistWorkingHoursRule {
  id              String          @id @default(cuid())
  therapistId     String
  therapist       Therapist       @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  weekday         Int
  startMinute     Int
  endMinute       Int
  effectiveFrom   DateTime?
  effectiveUntil  DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([therapistId, isActive])
}

model BookingRequest {
  id                   String               @id @default(cuid())
  therapistId          String
  therapist            Therapist            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patientUserId        String?
  patientUser          User?                @relation(fields: [patientUserId], references: [id], onDelete: SetNull)
  slotId               String?
  status               BookingRequestStatus @default(PENDING)
  patientName          String
  patientEmail         String?
  patientPhone         String?
  preferredDays        String               @default("")
  preferredTimeWindows String               @default("")
  message              String?
  heilmittel           String?
  kassenart            String?
  declinedReason       String?
  cancelReason         String?
  cancelledBy          CancelledBy?
  cancelledAt          DateTime?
  startsAt             DateTime?
  endsAt               DateTime?
  consentAcceptedAt    DateTime
  createdAt            DateTime             @default(now())
  responseDueAt        DateTime
  respondedAt          DateTime?
  confirmedSlotAt      DateTime?
  review               TherapistReview?
  scheduledSlots       ScheduledSlot[]

  @@index([therapistId, status, createdAt])
  @@index([patientUserId, status, createdAt])
}

model TherapistReview {
  id               String                @id @default(cuid())
  therapistId      String
  therapist        Therapist             @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patientUserId    String
  patientUser      User                  @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  bookingRequestId String                @unique
  bookingRequest   BookingRequest        @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  rating           Int
  comment          String?
  status           TherapistReviewStatus @default(PUBLISHED)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([therapistId, status, createdAt])
  @@index([patientUserId])
}

model TherapistRemovalLog {
  id          String   @id @default(cuid())
  therapistId String
  practiceId  String
  managerId   String
  createdAt   DateTime @default(now())
}

model PracticeDeletionLog {
  id             String   @id @default(cuid())
  practiceId     String
  practiceName   String
  managerId      String
  reason         String
  reasonDetail   String?
  linkedTherapists Int    @default(0)
  createdAt      DateTime @default(now())
}

model CertificationOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model SpecializationOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model HeilmittelOption {
  id                 String   @id @default(cuid())
  key                String   @unique
  label              String   @unique
  defaultDurationMin Int      @default(20)
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model TherapistService {
  id              String    @id @default(cuid())
  therapistId     String
  therapist       Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  heilmittelKey   String
  durationMin     Int
  bufferAfterMin  Int       @default(0)
  slotIntervalMin Int?
  isActive        Boolean   @default(true)
  colorHex        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([therapistId, heilmittelKey])
  @@index([therapistId, isActive])
}

model TherapistBlockedTime {
  id          String        @id @default(cuid())
  therapistId String
  therapist   Therapist     @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  title       String        @default("Blockiert")
  // Gesetzt bei mehrtägigen Abwesenheiten (Urlaub/Fortbildung/Krankheit/Sonstiges);
  // null bei Ad-hoc-Blockzeiten (Pause, Hausbesuch, …). Beide teilen sich dieselbe
  // Tabelle, damit Slot-Generator und Buchungs-Konfliktprüfung (POST /bookings)
  // automatisch beide Arten berücksichtigen.
  grund       AbsenceGrund?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([therapistId, startsAt, endsAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManagerPracticeAssignment {
  id         String          @id @default(cuid())
  managerId  String
  practiceId String
  manager    PracticeManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  practice   Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([managerId, practiceId])
}

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
}

// ─── Auth V2 ──────────────────────────────────────────────────────────────────

model UserFavoriteTherapist {
  id          String    @id @default(cuid())
  userId      String
  therapistId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([userId, therapistId])
  @@index([userId])
}

// ─── Phase 1: Angebotsseite + Kalender-Fundament ─────────────────────────────

// Mehrtägige Abwesenheiten (Urlaub, Fortbildung, Krankheit).
// Ergänzt TherapistBlockedTime (tagesinnere Blöcke) — beide Modelle bleiben
// nebeneinander bestehen: BlockedTime für Stunden-Blöcke, Absence für Tage.
model TherapistAbsence {
  id          String       @id @default(cuid())
  therapistId String
  therapist   Therapist    @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  von         DateTime
  bis         DateTime
  grund       AbsenceGrund @default(SONSTIGES)
  // true = Abwesenheit gilt für alle Therapeut:innen der Praxis (MVP: nur Info-Feld)
  ganzePraxis Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([therapistId, von, bis])
}

// Denormalisierte Kalenderansicht: wird beim CONFIRM eines BookingRequest atomar
// erzeugt und ist die einzige Datenquelle für Kalender, Timeline und Stats.
// Verhindert O(n-Inquiries)-Aggregation bei jedem Kalenderaufruf.
model ScheduledSlot {
  id               String              @id @default(cuid())
  bookingRequestId String?
  bookingRequest   BookingRequest?     @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  inquiryId        String?
  inquirySlotId    String?             @unique
  inquirySlot      InquirySlot?        @relation(fields: [inquirySlotId], references: [id], onDelete: SetNull)
  therapistId      String
  therapist        Therapist           @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  startsAt         DateTime
  endsAt           DateTime
  seriesIndex      Int                 @default(1)
  heilmittel       String              @default("")
  patientName      String
  patientPhone     String?
  status           ScheduledSlotStatus @default(SCHEDULED)
  // Therapeuten-interne Kurz-Notiz (max. 200 Zeichen, nicht für Patienten sichtbar)
  notiz            String?
  // Auto-Accept-Tracking: true wenn dieser Slot ohne manuelle Bestätigung
  // durch den Therapeuten entstanden ist (autoAcceptEnabled). Steuert die
  // "Neu automatisch bestätigt"-Anzeige im Anfragen-Tab und die Mitteilung.
  autoConfirmed        Boolean   @default(false)
  seenByTherapistAt    DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([therapistId, startsAt, status])
  @@index([bookingRequestId])
  @@index([inquiryId])
  @@index([therapistId, autoConfirmed, seenByTherapistAt])
}

// ─── Phase 2: Nachfrageseite + State Machine ──────────────────────────────────

enum InquiryStatus {
  SENT
  SEEN
  COUNTER_PROPOSED
  CONFIRMED
  CANCELLED
  DECLINED
  DECLINED_BY_PATIENT
  WITHDRAWN
  AUTO_CLOSED
  EXPIRED
}

enum InquiryCancelReason {
  PRAXIS_KRANKHEIT
  PRAXIS_ABSAGE
  PATIENT_WUNSCH
  SONSTIGES
}

enum InquiryCancelActor {
  PRAXIS
  PATIENT
}

// Patientenseitige Behandlungsanfrage — Wurzel einer Buchungsserie.
// Bis zu 3 Inquiries (je Therapeut eine) können einer PatientRequest zugeordnet sein.
model PatientRequest {
  id            String    @id @default(cuid())
  patientUserId String
  patientUser   User      @relation("PatientRequests", fields: [patientUserId], references: [id], onDelete: Cascade)
  heilmittel    String
  kassenart     String    @default("")
  frequenz      String    @default("X1")
  anzahlTermine Int       @default(6)
  suchtyp       String    @default("SERIE")
  message       String?
  migrated      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  timeWindows   PatientTimeWindow[]
  prescription  PrescriptionData?
  inquiries     Inquiry[]

  @@index([patientUserId, createdAt])
}

// Zeitfenster-Präferenzen des Patienten (Wochentag + Uhrzeit-Korridor).
// Ein Patient kann mehrere Fenster pro Wochentag angeben — überlappende
// werden vor Matching-Prüfung normalisiert (zusammengeführt).
model PatientTimeWindow {
  id               String         @id @default(cuid())
  patientRequestId String
  patientRequest   PatientRequest @relation(fields: [patientRequestId], references: [id], onDelete: Cascade)
  weekday          Int
  vonMinute        Int
  bisMinute        Int
  createdAt        DateTime       @default(now())

  @@index([patientRequestId])
}

// GKV-Rezeptdaten (Privatpatienten: prescription = null).
model PrescriptionData {
  id                    String         @id @default(cuid())
  patientRequestId      String         @unique
  patientRequest        PatientRequest @relation(fields: [patientRequestId], references: [id], onDelete: Cascade)
  icdCode               String?
  heilmittelposNr       String?
  indikationsSchluessel String?
  arztName              String?
  arztDatum             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

// Einzelne Anfrage bei einem Therapeuten.
// Snapshot-Felder frieren PatientRequest-Daten zum Zeitpunkt der Erstellung ein.
// parallelAnfragenAnzahl: Anzahl aktiver Parallel-Inquiries (DSGVO: nur Zahl, keine Namen).
model Inquiry {
  id                     String              @id @default(cuid())
  patientRequestId       String
  patientRequest         PatientRequest      @relation(fields: [patientRequestId], references: [id], onDelete: Cascade)
  therapistId            String
  therapist              Therapist           @relation("TherapistInquiries", fields: [therapistId], references: [id], onDelete: Cascade)
  status                 InquiryStatus       @default(SENT)

  // Snapshot-Felder
  heilmittel             String
  kassenart              String              @default("")
  frequenz               String              @default("X1")
  anzahlTermine          Int                 @default(6)
  suchtyp                String              @default("SERIE")
  patientFreitext        String?
  patientName            String
  patientEmail           String?
  patientPhone           String?
  parallelAnfragenAnzahl Int                 @default(0)

  // State-Machine-Felder
  cancelReason           InquiryCancelReason?
  cancelActor            InquiryCancelActor?
  cancelledAt            DateTime?
  ablehnungsgrund        String?
  respondedAt            DateTime?
  responseDueAt          DateTime
  reminderSentAt         DateTime?

  // Vom Patienten gewünschter Termin (nur bei suchtyp=EINZELTERMIN)
  wunschDatum            DateTime?
  wunschUhrzeitVon       Int?
  wunschUhrzeitBis       Int?

  // Bestätigter Termin (Datum + Uhrzeit in Minuten seit Mitternacht)
  confirmedDatum         DateTime?
  confirmedUhrzeitVon    Int?
  confirmedUhrzeitBis    Int?

  migrated               Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  inquirySlots           InquirySlot[]

  @@index([therapistId, status, createdAt])
  @@index([patientRequestId])
}

model InquirySlot {
  id            String            @id @default(cuid())
  inquiryId     String
  inquiry       Inquiry           @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  datum         String
  uhrzeitVon    Int
  uhrzeitBis    Int
  status        InquirySlotStatus @default(PENDING)
  scheduledSlot ScheduledSlot?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([inquiryId])
}

// ─── Kurs-Erweiterung ────────────────────────────────────────────────────────

enum CourseLocationType {
  ONSITE
  ONLINE
  HYBRID
}

enum CourseRunStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CANCELLED
}

enum CourseEnrollmentStatus {
  EMAIL_UNCONFIRMED
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  WAITLISTED
}

model CourseCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  courses   Course[]
}

model Course {
  id          String @id @default(cuid())

  therapistId String?
  therapist   Therapist? @relation("TherapistCourses", fields: [therapistId], references: [id], onDelete: Cascade)
  practiceId  String?
  practice    Practice?  @relation("PracticeCourses", fields: [practiceId], references: [id], onDelete: Cascade)

  categoryKey String
  category    CourseCategory @relation(fields: [categoryKey], references: [key])

  title              String
  description        String
  targetAudience     String?
  prerequisites      String?
  instructorName     String
  instructorBio      String?
  contactInfo        String?
  cancellationPolicy String?
  locationType       CourseLocationType

  zppDocUrl String?

  healthInsuranceEligible Boolean @default(false)
  zppVerified             Boolean @default(false)

  reviewStatus ReviewStatus @default(DRAFT)
  adminNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs CourseRun[]

  @@index([therapistId, reviewStatus])
  @@index([practiceId, reviewStatus])
  @@index([categoryKey, reviewStatus])
}

model CourseRun {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  label String?

  status CourseRunStatus @default(DRAFT)

  address   String?
  city      String?
  onlineUrl String?

  maxParticipants Int
  minParticipants Int?
  waitlistEnabled Boolean @default(false)
  waitlistMax     Int?

  bookingDeadline DateTime?

  priceAmount   Int?
  priceCurrency String @default("EUR")

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions    CourseSession[]
  enrollments CourseEnrollment[]

  @@index([courseId, status])
}

model CourseSession {
  id          String    @id @default(cuid())
  courseRunId String
  courseRun   CourseRun @relation(fields: [courseRunId], references: [id], onDelete: Cascade)

  startsAt DateTime
  endsAt   DateTime
  location String?

  createdAt DateTime @default(now())

  @@index([courseRunId, startsAt])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseRunId String
  courseRun   CourseRun @relation(fields: [courseRunId], references: [id])

  patientName  String
  patientEmail String?
  patientPhone String?
  message      String?

  status CourseEnrollmentStatus @default(EMAIL_UNCONFIRMED)

  confirmToken         String?  @unique
  cancelToken          String   @unique
  cancelTokenExpiresAt DateTime?

  declineReason    String?
  cancelledBy      String?
  cancelledAt      DateTime?
  confirmedEmailAt DateTime?

  consentAcceptedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseRunId, status])
  @@index([patientEmail])
  @@index([confirmToken])
  @@index([cancelToken])
}
