generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  SUSPENDED
}

enum EmploymentStatus {
  SELF_EMPLOYED
  PREPARING
}

enum LinkStatus {
  PROPOSED
  CONFIRMED
  DISPUTED
  REJECTED
}

enum SuggestionType {
  THERAPIST_NAME
  PRACTICE_NAME
  SPECIALTY
  CITY
}

enum Role {
  therapist
  admin
  patient
}

enum BookingMode {
  DIRECTORY_ONLY
  FIRST_APPOINTMENT_REQUEST
}

enum BookingRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  EXPIRED
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

enum SlotSource {
  MANUAL
  WORKING_HOURS
}

enum AppFeedbackStatus {
  NEW
  RESOLVED
}

enum TherapistReviewStatus {
  PUBLISHED
  HIDDEN
  REPORTED
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String?
  sessionToken              String?   @unique
  sessionTokenExpiresAt     DateTime?
  role                   Role
  firstName                   String?
  lastName                    String?
  emailVerificationToken      String?
  emailVerifiedAt             DateTime?
  requiresEmailVerification   Boolean   @default(false)
  // Password reset (added via migration 20260409183000)
  passwordResetToken          String?
  passwordResetExpiresAt      DateTime?
  // Phone (added via migration 20260511090000)
  phone                       String?
  expoPushToken               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  therapistProfile       Therapist?              @relation("TherapistUser")
  favoriteTherapists     UserFavoriteTherapist[]
  bookingRequests        BookingRequest[]
  appFeedbacks           AppFeedback[]
  therapistReviews       TherapistReview[]
}

model Therapist {
  id                    String       @id @default(cuid())
  email                 String       @unique
  userId                String?      @unique
  user                  User?        @relation("TherapistUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName              String
  professionalTitle     String
  city                  String
  bio                   String?
  homeVisit             Boolean      @default(false)
  isFreelancer          Boolean      @default(true)
  specializations       String
  languages             String
  certifications        String       @default("")
  // Verordnungsfähige Heilmittel, die der/die Therapeut:in behandelt (CSV, wie
  // specializations/certifications). Gesetzt bei Aktivierung von bookingMode =
  // FIRST_APPOINTMENT_REQUEST, dann automatisch für Patient:innen sichtbar.
  heilmittel            String       @default("")
  kassenart             String       @default("")
  availability          String       @default("")
  serviceRadiusKm       Float?
  homeLat               Float        @default(0)
  homeLng               Float        @default(0)
  isVisible             Boolean      @default(true)
  reviewStatus          ReviewStatus @default(PENDING_REVIEW)
  // Employment status (added via migration 20260613120000) — PREPARING profiles are never publicly visible
  employmentStatus      EmploymentStatus @default(SELF_EMPLOYED)
  passwordHash          String?
  sessionToken              String?   @unique
  sessionTokenExpiresAt     DateTime?
  photo                 String?
  expoPushToken         String?
  visibilityPreference  String       @default("hidden")
  isPublished           Boolean      @default(false)
  bookingMode           BookingMode  @default(DIRECTORY_ONLY)
  nextFreeSlotAt        DateTime?
  slots                 TherapistSlot[]
  workingHoursRules     TherapistWorkingHoursRule[]
  // Location (added via migration 20260409150000)
  postalCode            String?
  street                String?
  houseNumber           String?
  locationPrecision     String       @default("approximate")
  latitude              Float?
  longitude             Float?
  // Compliance (added via migration 20260409113000)
  taxRegistrationStatus  String?
  healthAuthorityStatus  String?
  complianceUpdatedAt    DateTime?
  // Demographics (added via migration 20260426080704)
  gender                String?
  // Phone (added via migration 20260511090000)
  phone                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  links                 TherapistPracticeLink[]
  documents             TherapistDocument[]
  bookingRequests       BookingRequest[]
  favoritedBy           UserFavoriteTherapist[]
  reviews               TherapistReview[]
}

model Practice {
  id                String       @id @default(cuid())
  name              String
  city              String
  address           String?
  phone             String?
  hours             String?
  lat               Float        @default(0)
  lng               Float        @default(0)
  reviewStatus      ReviewStatus @default(PENDING_REVIEW)
  description       String?
  homeVisit         Boolean      @default(false)
  logo              String?
  photos            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  links             TherapistPracticeLink[]
}

model SearchSuggestion {
  id         String         @id @default(cuid())
  text       String
  normalized String
  type       SuggestionType
  entityId   String?
  weight     Int            @default(1)

  @@index([normalized])
}

model TherapistPracticeLink {
  id           String     @id @default(cuid())
  therapistId  String
  practiceId   String
  status       LinkStatus @default(PROPOSED)
  initiatedBy  String     @default("THERAPIST") // "ADMIN" | "THERAPIST"
  createdAt    DateTime   @default(now())
  therapist    Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice     Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([therapistId, practiceId])
}

model TherapistDocument {
  id           String    @id @default(cuid())
  therapistId  String
  filename     String    // stored filename (UUID-based, no path)
  originalName String    // original filename from upload
  mimetype     String
  uploadedAt   DateTime  @default(now())
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  authorName  String   @default("Revio Team")
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppFeedback {
  id              String            @id @default(cuid())
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String
  message         String
  status          AppFeedbackStatus @default(NEW)
  isAuthenticated Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model TherapistSlot {
  id                  String      @id @default(cuid())
  therapistId         String
  therapist           Therapist   @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  startsAt            DateTime
  durationMin         Int         @default(20)
  status              SlotStatus  @default(AVAILABLE)
  booking             BookingRequest?
  createdAt           DateTime    @default(now())
  // Working-hours materializer (added via migration 20260626120000) — lets the
  // materializer tell its own generated AVAILABLE slots apart from manually
  // created ones, so rule changes/regeneration never touch manual slots.
  source              SlotSource  @default(MANUAL)
  workingHoursRuleId  String?
  workingHoursRule    TherapistWorkingHoursRule? @relation(fields: [workingHoursRuleId], references: [id], onDelete: SetNull)

  @@unique([therapistId, startsAt])
  @@index([therapistId, status, startsAt])
  @@index([workingHoursRuleId])
}

// Recurring weekly working-hours rule ("Arbeitszeiten"). One row covers a
// single contiguous time block on a single weekday — a weekday with a lunch
// gap (e.g. Mo 08-12 and 14-18) is two rows with the same weekday, not a
// schema change. See docs/claude-therapist-working-hours-plan.md.
model TherapistWorkingHoursRule {
  id              String          @id @default(cuid())
  therapistId     String
  therapist       Therapist       @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  // 0-6, matches JS Date#getDay() (0=So..6=Sa) — same convention as
  // WEEKDAY_OPTIONS in apps/mobile/src/utils/recurring-slots.js. Using
  // ISO/Monday-first numbering here instead would silently mismatch the
  // existing Wochentage UI/logic by one day.
  weekday         Int
  startMinute     Int
  endMinute       Int
  durationMin     Int             @default(20)
  intervalMin     Int?
  effectiveFrom   DateTime?
  effectiveUntil  DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  slots           TherapistSlot[]

  @@index([therapistId, isActive])
}

model BookingRequest {
  id                   String               @id @default(cuid())
  therapistId          String
  therapist            Therapist            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patientUserId        String?
  patientUser          User?                @relation(fields: [patientUserId], references: [id], onDelete: SetNull)
  slotId               String?              @unique
  slot                 TherapistSlot?       @relation(fields: [slotId], references: [id], onDelete: SetNull)
  status               BookingRequestStatus @default(PENDING)
  patientName          String
  patientEmail         String?
  patientPhone         String?
  preferredDays        String               @default("")
  preferredTimeWindows String               @default("")
  message              String?
  heilmittel           String?
  kassenart            String?
  declinedReason       String?
  consentAcceptedAt    DateTime
  createdAt            DateTime             @default(now())
  responseDueAt        DateTime
  respondedAt          DateTime?
  confirmedSlotAt      DateTime?
  review               TherapistReview?

  @@index([therapistId, status, createdAt])
  @@index([patientUserId, status, createdAt])
}

model TherapistReview {
  id               String                @id @default(cuid())
  therapistId      String
  therapist        Therapist             @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  patientUserId    String
  patientUser      User                  @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  bookingRequestId String                @unique
  bookingRequest   BookingRequest        @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  rating           Int
  comment          String?
  status           TherapistReviewStatus @default(PUBLISHED)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([therapistId, status, createdAt])
  @@index([patientUserId])
}

model CertificationOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model SpecializationOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

// Verordnungsfähige Heilmittel-Kategorien (KG, MT, MLD, ...) — bewusst getrennt
// von CertificationOption: Fortbildungen sind absolvierte Zusatzqualifikationen,
// Heilmittel sind die offiziellen, abrechenbaren Leistungskategorien, die ein/e
// Therapeut:in anbietet. Gate für die Aktivierung von Terminanfragen.
model HeilmittelOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
}

model UserFavoriteTherapist {
  id          String    @id @default(cuid())
  userId      String
  therapistId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([userId, therapistId])
  @@index([userId])
}
