{
  "expo": {
    "name": "Revio",
    "slug": "revo",
    "scheme": "revo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#2F3E46"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Revio benötigt deinen Standort, um Therapeuten in deiner Nähe zu finden.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Revio benötigt deinen Standort, um Therapeuten in deiner Nähe zu finden."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#2F3E46"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "revo"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Revio benötigt deinen Standort, um Therapeuten in deiner Nähe zu finden."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#2F3E46",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "453d86fe-08c1-4852-ae2a-a9991f64c845"
      }
    },
    "owner": "vucenovic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/453d86fe-08c1-4852-ae2a-a9991f64c845"
    }
  }
}
