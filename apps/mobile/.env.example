# ── API ───────────────────────────────────────────────────────────────────────
# Lokale Entwicklung: LAN-IP deines Rechners (nicht localhost — das funktioniert
# auf dem Gerät nicht). Beispiel: http://192.168.1.42:4000
#
# WICHTIG: Für EAS Update / EAS Build wird EXPO_PUBLIC_API_URL als
# EAS Environment Variable im Expo Dashboard gesetzt (production + preview).
# Hier nie die Production-URL eintragen — diese Datei gilt nur lokal.
EXPO_PUBLIC_API_URL=http://localhost:4000

# ── Maps ──────────────────────────────────────────────────────────────────────
# Google Maps SDK for Android braucht einen eigenen API Key, sonst crasht die
# Karte beim Öffnen auf Android (iOS nutzt Apple Maps, kein Key nötig).
# Key in der Google Cloud Console anlegen (Maps SDK for Android aktivieren,
# auf Package de.myrevio.app + SHA-1 einschränken) und als EAS Environment
# Variable im Expo Dashboard setzen (production + preview) — nicht hier lokal
# committen. Ohne gesetzten Key bleibt apiKey leer und die Karte crasht weiter.
GOOGLE_MAPS_API_KEY=
