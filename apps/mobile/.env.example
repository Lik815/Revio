# ── API ───────────────────────────────────────────────────────────────────────
# Lokale Entwicklung: LAN-IP deines Rechners (nicht localhost — das funktioniert
# auf dem Gerät nicht). Beispiel: http://192.168.1.42:4000
#
# WICHTIG: Für EAS Update / EAS Build wird EXPO_PUBLIC_API_URL als
# EAS Environment Variable im Expo Dashboard gesetzt (production + preview).
# Hier nie die Production-URL eintragen — diese Datei gilt nur lokal.
EXPO_PUBLIC_API_URL=http://localhost:4000
